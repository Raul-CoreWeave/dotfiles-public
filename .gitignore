# Common secret-bearing patterns; future-proof
.env
.env.*
*.pem
*.key
*_token
*_token.txt

# OS / editor
.DS_Store
*~
*.swp

# Backup files created by install.sh when it replaces a non-symlink
*.bak
*.bak.*
*.pre-*

# Never commit a plaintext zshrc — only the sanitized template is tracked.
shell/zshrc

# Local-only overrides (per-machine tweaks not meant to sync)
local/
*.local

# Claude Code runtime state — auto-generated per session, never committed
claude/cache/
claude/sessions/
claude/shell-snapshots/
claude/telemetry/
claude/usage-data/
claude/file-history/
claude/downloads/
claude/paste-cache/
claude/backups/
claude/session-env/
claude/tasks/
claude/plans/
claude/chrome/
claude/history.jsonl
claude/mcp-needs-auth-cache.json
claude/policy-limits.json

# Claude Code plugin payloads (recreatable from installed_plugins.json)
claude/plugins/cache/
claude/plugins/data/
claude/plugins/marketplaces/
claude/plugins/install-counts-cache.json
claude/plugins/known_marketplaces.json

# Claude Code timestamped backups (auto-created on CLAUDE.md edits)
claude/*.bak-*

# Claude Code housekeeping markers
claude/.last-cleanup

# Per-project session state.
claude/projects/

# Generated by install.sh — merged settings from portable base + optional overlay.
claude/_generated/

# Optional private overlay (org/job-specific; never committed to the public repo)
claude/CLAUDE.local.md
claude/settings.private.json
claude/plugins/installed_plugins.private.json
repos.txt
